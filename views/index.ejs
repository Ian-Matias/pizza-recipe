<!DOCTYPE html>
<html>

<head>
  <title>Taco Recipes</title>
  <link rel="stylesheet" type="text/css" href="/styles/main.css">
</head>

<body>
  <a href="/"><h1>Pizza City 🍕</h1></a>

  <form action="/recipe" method="POST" class="buttons">
    <button type="submit" value="cheese" name="choice">🧀</button>
    <button type="submit" value="pepperoni" name="choice">🍕</button>
    <button type="submit" value="pineapple" name="choice">🍍</button>
  </form>
  <div id="recipeContainer" class="hidden">
  <% if (locals.recipe) {%>
    <!-- Else, show the recipe name e.g. <h2>Recipe name</h2>-->
    <h2 id="recipeTitle"> <%= recipe.name %> </h2>
  

    <h3>Ingredients:</h3>
    <ul id="ingredientsList">
      <li>
        <%= recipe.ingredients.protein.name %>, <%= recipe.ingredients.protein.preparation %>
      </li>

      <li>
        <%= recipe.ingredients.salsa.name %>
      </li>

      <% recipe.ingredients.toppings.forEach(topping=> {%>
      <li>
        <%= topping.quantity %> of <%= topping.name %>
      </li>
      <% }) %>
    </ul>

    <!-- If no recipe yet, show: -->
 <%} else {%>
        <h2>Pick your favourite taco ingredient 👆</h2>
        <%}%>
  </div>
</body>

</html>